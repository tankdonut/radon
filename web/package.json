{
  "name": "radon-web",
  "private": true,
  "version": "0.4.0",
  "description": "Radon Terminal — market structure reconstruction instrument with real-time IB streaming and AI chat.",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n next,ib -c cyan,yellow \"next dev\" \"node ../scripts/ib_realtime_server.js\"",
    "dev:next": "next dev",
    "dev:verbose": "concurrently -n next,ib -c cyan,yellow \"NEXT_DEBUG_LOGGING=1 next dev\" \"node ../scripts/ib_realtime_server.js --verbose\"",
    "dev:verbose:next": "concurrently -n next,ib -c cyan,yellow \"NEXT_DEBUG_LOGGING=1 next dev\" \"node ../scripts/ib_realtime_server.js\"",
    "dev:verbose:ib": "concurrently -n next,ib -c cyan,yellow \"next dev\" \"node ../scripts/ib_realtime_server.js --verbose\"",
    "dev:prices": "node ../scripts/ib_realtime_server.js",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "NODE_ENV=test ASSISTANT_MOCK=1 tsx --test tests/**/*.test.ts",
    "test:ib": "python3 ../scripts/test_ib_realtime.py"
  },
  "dependencies": {
    "liveline": "^0.0.6",
    "lucide-react": "^0.544.0",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@sinclair/typebox": "^0.34.48",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.18.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "playwright": "^1.58.2",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.0",
    "typescript": "^5.6.3",
    "vitest": "^4.0.18",
    "ws": "^8.19.0"
  }
}
